# Offer Catcher AI config
# Copy this file to .env for local development. Do not commit real keys.

DASHSCOPE_API_KEY=your-bailian-api-key
DASHSCOPE_MODEL=qwen3.5-omni-plus-2026-03-15
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional OpenAI-compatible fallback. Used only when no DashScope/Bailian key is set.
# OPENAI_API_KEY=your-openai-compatible-key
# OPENAI_MODEL=your-model-name
# OPENAI_BASE_URL=https://api.example.com/v1

# Test-only guard. The pytest suite enables this so local Streamlit secrets are ignored.
# OFFER_CATCHER_DISABLE_STREAMLIT_SECRETS=1
